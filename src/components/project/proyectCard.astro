---
import { HiArrowRight } from "react-icons/hi";

export interface Props {
  titulo: string;
  descripcion: string;
  imagen: string;
  tecnologias: string[];
  demo: string;
  codigo: string;
  categoria?: string;
  index: number; 
}

const { titulo, descripcion, imagen, tecnologias, demo, codigo, categoria, index } =
  Astro.props;
---

<div
  data-index={index}
  data-categoria={categoria ?? ""}
  class="project-card group relative z-10 flex w-[400px] flex-col overflow-hidden rounded-3xl
         bg-gradient-to-br from-white/10 to-white/5 backdrop-blur-xl border border-white/10
         shadow-[0_8px_32px_rgba(0,0,0,0.3)]
         hover:shadow-[0_20px_60px_rgba(0,0,0,0.4)] hover:border-white/20
         transition-all duration-700 hover:-translate-y-2 lg:w-[320px]"
>
  <!-- AMBIENT GLOW -->
  <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/0 to-cyan-500/0 
              group-hover:from-purple-500/20 group-hover:to-cyan-500/20 
              rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 
              transition-all duration-700 -z-10"></div>

  <!-- IMAGE -->
  <div class="relative overflow-hidden">
    <img
      src={imagen}
      alt={`Imagen del proyecto ${titulo}`}
      class="h-50 w-full rounded-2xl object-cover p-3
             transition-transform duration-700 group-hover:scale-110"
    />
    
    <!-- GRADIENT OVERLAY on hover -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent 
                opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
    
    <!-- CATEGORY BADGE -->
    {categoria && (
      <div class="absolute bottom-6 left-6">
        <span class="px-3 py-1.5 rounded-lg
                     bg-white/10 backdrop-blur-xl border border-white/20
                     text-white/80 text-xs font-semibold uppercase tracking-wider">
          {categoria}
        </span>
      </div>
    )}
  </div>

  <!-- CONTENT -->
  <div class="flex grow flex-col px-4 pb-4">
    
    <!-- TITLE -->
    <h3 class="text-xl font-semibold text-white mb-2
               group-hover:text-transparent group-hover:bg-gradient-to-r 
               group-hover:from-purple-400 group-hover:to-cyan-400 
               group-hover:bg-clip-text transition-all duration-500">
      {titulo}
    </h3>

    <!-- TECH STACK -->
    <div class="my-2 flex flex-wrap gap-2">
      {tecnologias.map((tech) => (
        <span class="rounded-lg px-3 py-1.5
                     bg-white/5 backdrop-blur-xl border border-white/10
                     text-white/70 text-xs font-medium
                     hover:bg-white/10 hover:text-white hover:border-white/20
                     transition-all duration-300">
          {tech}
        </span>
      ))}
    </div>

    <!-- DESCRIPTION -->
    <p class="flex grow text-white/60 text-sm leading-relaxed">{descripcion}</p>

    <!-- DIVIDER -->
    <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent my-4"></div>

    <!-- LINKS -->
    <div class="mt-auto flex justify-between gap-4">
      <a
        class="group/link flex items-center justify-start text-white/80 hover:text-white
               font-semibold text-base transition-all duration-300"
        target="_blank"
        rel="noopener noreferrer"
        href={demo}
      >
        Demo
        <HiArrowRight
          className="ml-1 transition-transform duration-300 group-hover/link:translate-x-1"
          size={18}
        />
      </a>

      {codigo && (
        <a
          class="group/link flex items-center justify-start text-white/80 hover:text-white
                 font-semibold text-base transition-all duration-300"
          href={codigo}
          target="_blank"
          rel="noopener noreferrer"
        >
          Código
          <HiArrowRight
            className="ml-1 transition-transform duration-300 group-hover/link:translate-x-1"
            size={18}
          />
        </a>
      )}
    </div>
  </div>
</div>

<style>
  /* Typography */
  h3, p, span, a {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>