---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<article class="service-card group relative">
  
  <!-- AMBIENT GLOW (appears on hover) -->
  <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/0 to-cyan-500/0 
              group-hover:from-purple-500/20 group-hover:to-cyan-500/20 
              rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 
              transition-all duration-700 -z-10"></div>

  <!-- CARD CONTAINER -->
  <div class="relative h-full flex flex-col items-center justify-center overflow-hidden rounded-3xl
              bg-gradient-to-br from-white/10 to-white/5
              backdrop-blur-xl border border-white/10
              p-8 md:p-10
              shadow-[0_8px_32px_rgba(0,0,0,0.2)]
              hover:shadow-[0_20px_60px_rgba(0,0,0,0.4)]
              hover:border-white/20
              transition-all duration-700 ease-out
              hover:-translate-y-2">

    <!-- ICON CONTAINER -->
    <div class="relative mb-6">
      <!-- GLOW BACKGROUND -->
      <div class="absolute inset-0 bg-gradient-to-r from-purple-500/20 to-cyan-500/20 
                  rounded-2xl blur-xl opacity-0 group-hover:opacity-100 
                  transition-opacity duration-500"></div>
      
      <!-- ICON WRAPPER -->
      <div class="relative p-4 rounded-2xl
                  bg-white/5 backdrop-blur-xl border border-white/10
                  group-hover:bg-white/10 group-hover:border-white/20 group-hover:scale-110
                  transition-all duration-500">
        <div class="w-14 h-14 flex items-center justify-center
                    text-transparent bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text
                    [&>div]:text-transparent [&>div]:bg-gradient-to-r [&>div]:from-purple-400 [&>div]:to-cyan-400 [&>div]:bg-clip-text
                    [&_svg]:stroke-current [&_svg]:text-purple-400
                    group-hover:[&_svg]:text-cyan-400
                    transition-all duration-500">
          <slot name="icon">
            <!-- Fallback icon si no se proporciona -->
            <svg class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </slot>
        </div>
      </div>
    </div>

    <!-- TITLE -->
    <h3 class="text-2xl md:text-3xl font-bold text-center mb-4
               text-white
               group-hover:text-transparent group-hover:bg-gradient-to-r 
               group-hover:from-purple-400 group-hover:to-cyan-400 
               group-hover:bg-clip-text
               transition-all duration-500">
      {title}
    </h3>

    <!-- DIVIDER -->
    <div class="h-px w-16 bg-gradient-to-r from-transparent via-white/20 to-transparent mb-4
                group-hover:w-24 transition-all duration-500"></div>

    <!-- DESCRIPTION -->
    <p class="text-center text-white/60 text-base md:text-lg leading-relaxed
              group-hover:text-white/80 transition-colors duration-300">
      {description}
    </p>

    <!-- DECORATIVE CORNER ACCENT -->
    <div class="absolute top-4 right-4 w-12 h-12 
                border-t-2 border-r-2 border-white/0 rounded-tr-2xl
                group-hover:border-white/20 transition-all duration-500"></div>
    <div class="absolute bottom-4 left-4 w-12 h-12 
                border-b-2 border-l-2 border-white/0 rounded-bl-2xl
                group-hover:border-white/20 transition-all duration-500"></div>

  </div>
</article>

<style>
  /* Typography */
  h3, p {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Ensure smooth transforms */
  .service-card {
    will-change: transform;
  }
</style>