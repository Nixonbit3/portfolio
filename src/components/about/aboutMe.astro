---
import MiFoto from "../../assets/img/MiFoto.webp";
---

<section class="relative py-20 md:py-28 overflow-hidden bg-black">
  
  <!-- AMBIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[140px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[140px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 md:px-8">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- LEFT: IMAGE -->
      <div class="relative order-2 md:order-1" data-reveal>
        <!-- DECORATIVE BACKGROUND -->
        <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/20 to-cyan-500/20 rounded-3xl blur-2xl opacity-50"></div>
        
        <div class="relative group">
          <!-- MAIN IMAGE CONTAINER -->
          <div class="relative overflow-hidden rounded-3xl
                     bg-gradient-to-br from-white/10 to-white/5
                     backdrop-blur-xl border border-white/10
                     shadow-2xl shadow-black/50
                     transition-all duration-700 ease-out
                     hover:shadow-[0_40px_80px_-20px_rgba(120,54,207,0.4)]
                     hover:scale-[1.02]">
            <img 
              src={MiFoto.src} 
              alt="Nixon - Game Developer"
              class="w-full h-auto object-cover
                     transition-all duration-700 ease-out
                     group-hover:scale-105"
            />
            
            <!-- GRADIENT OVERLAY ON HOVER -->
            <div class="absolute inset-0 bg-gradient-to-t from-purple-500/10 via-transparent to-transparent 
                        opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          </div>

          <!-- FLOATING BADGE -->
          <div class="absolute -bottom-6 -right-6 px-6 py-3 rounded-2xl
                     bg-white/10 backdrop-blur-2xl border border-white/20
                     shadow-xl
                     transform group-hover:translate-y-[-4px] transition-transform duration-500">
            <div class="flex items-center gap-3">
              <div class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
              </div>
              <span class="text-white font-semibold text-sm">Available</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: CONTENT -->
      <div class="order-1 md:order-2 space-y-6" data-reveal data-delay="200">
        
        <!-- GREETING -->
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight leading-[1.1]">
          <span class="text-white/60">My name is</span>
          <br />
          <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
            Nixon
          </span>
        </h2>

        <!-- MAIN DESCRIPTION -->
<div class="space-y-4 text-base md:text-lg text-white/60 leading-relaxed">
  <p>
    I'm <span data-es="Junior Unity Developer" class="text-white/90 font-semibold">a Junior Unity Developer</span> focused on
    <span class="text-white/90 font-semibold">gameplay and mobile games</span>, and
    <span class="text-white/90 font-semibold">a graduate in Video Game Design and Development</span>
    from <span class="text-white/90 font-semibold">CITM (UPC)</span>.
  </p>

  <p>
    I just shipped <span class="text-white/90 font-semibold">Air Bomb</span>, my first Android game, built solo from start to finish with
    <span class="text-white/80">Unity and C#</span>: View/Controller architecture, data-driven levels with ScriptableObjects, event-based communication, DOTween, JSON persistence and cross-scene audio.
  </p>

  <p>
    What I bring: <span class="text-white/90 font-semibold">gameplay programming, UI systems and Android builds</span>, with architecture habits that separate logic from presentation. On top of that, the foundation from my degree:
    <span class="text-white/80">C++, custom engines, VR/AR, 3D (Blender, 3ds Max, Maya) and UI/UX</span>.
  </p>

  <p>
    I stand out for my <span class="text-white/90 font-semibold">ability to work independently</span>, my debugging discipline (stack traces, prefab reference hunting and testing on real devices) and how fast I learn. I'm looking for my
    <span class="text-white/90 font-semibold">first role as a Junior Unity / Gameplay Developer</span>
    at a studio or mobile team, in Barcelona or remote.
  </p>
</div>


        <!-- TECH HIGHLIGHTS -->
        <div class="flex flex-wrap gap-3 pt-4">
          {["Unity", "C#", "Android", "Unreal", "Blender"].map((tech) => (
            <span class="px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10
                         text-white/80 text-sm font-medium
                         hover:bg-white/10 hover:border-white/20 transition-all duration-300">
              {tech}
            </span>
          ))}
        </div>

      </div>

    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -30px); }
  }

  @keyframes floatDelayed {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-30px, 30px); }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: floatDelayed 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-delay="200"].revealed {
    transition-delay: 0.2s;
  }

  /* Typography */
  h2, p, span {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.2,
      rootMargin: '0px 0px -100px 0px'
    }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    observer.observe(el);
  });
</script>