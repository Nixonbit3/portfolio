---
import ServiceCard from "./ServiceCard.astro";
---

<section class="relative py-32 md:py-40 overflow-hidden bg-black">
  
  <!-- AMBIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[140px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[140px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <!-- HEADER -->
    <div class="text-center mb-20" data-reveal>
      
      <!-- LABEL -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10 mb-6">
        <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M11 17a1 1 0 001.447.894l4-2A1 1 0 0017 15V9.236a1 1 0 00-1.447-.894l-4 2a1 1 0 00-.553.894V17zM15.211 6.276a1 1 0 000-1.788l-4.764-2.382a1 1 0 00-.894 0L4.789 4.488a1 1 0 000 1.788l4.764 2.382a1 1 0 00.894 0l4.764-2.382zM4.447 8.342A1 1 0 003 9.236V15a1 1 0 00.553.894l4 2A1 1 0 009 17v-5.764a1 1 0 00-.553-.894l-4-2z"/>
        </svg>
        <span class="text-white/70 text-sm font-medium">Fortalezas</span>
      </div>

      <!-- TITLE -->
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">
          En qué
        </span>
        <br />
        <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
          soy fuerte
        </span>
      </h2>

      <!-- SUBTITLE -->
      <p class="text-xl text-white/60 max-w-2xl mx-auto">
        Lo que aporto hoy a un equipo que desarrolla juegos con Unity
      </p>
    </div>

    <!-- SERVICES GRID -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8" data-reveal data-delay="200">
      
      <!-- GAMEPLAY PROGRAMMING -->
      <ServiceCard
        title="Gameplay Programming"
        description="Sistemas jugables y mecánicas en Unity y C#: control del jugador, oleadas de enemigos, puntuación y game feel."
      >
        <div slot="icon" class="text-5xl">
          <svg class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
      </ServiceCard>

      <!-- ARQUITECTURA -->
      <ServiceCard
        title="Arquitectura y código limpio"
        description="Separación entre lógica y presentación, diseño orientado a datos con ScriptableObjects y comunicación por eventos."
      >
        <div slot="icon" class="text-5xl">
          <svg class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
          </svg>
        </div>
      </ServiceCard>

      <!-- MOBILE / ANDROID -->
      <ServiceCard
        title="Mobile & Android"
        description="Builds de Android, sistemas de UI y HUD, persistencia en JSON y pruebas en dispositivo real."
      >
        <div slot="icon" class="text-5xl">
          <svg class="w-full h-full" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </div>
      </ServiceCard>

    </div>

  </div>
</section>

<style>
  @keyframes float {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(30px, -30px);
    }
  }

  @keyframes floatDelayed {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-30px, 30px);
    }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: floatDelayed 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  /* Reveal animations */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-delay="200"].revealed {
    transition-delay: 0.2s;
  }

  /* Typography */
  h2, p, span {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.2,
      rootMargin: '0px 0px -100px 0px'
    }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    observer.observe(el);
  });
</script>