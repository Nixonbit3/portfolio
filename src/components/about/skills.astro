---
// Tecnologías de Game Dev & Web
const skills = [
  { name: "Unity", icon: "unity" },
  { name: "C#", icon: "csharp" },
  { name: "C++", icon: "cplusplus" },
  { name: "Blender", icon: "blender" },
  { name: "Maya", icon: "maya" },
  { name: "Unreal Engine", icon: "unrealengine" },
  { name: "Figma", icon: "figma" },
  { name: "Trello", icon: "trello" },
  { name: "GitHub", icon: "github" },
  { name: "Photoshop", icon: "photoshop" },
  { name: "Illustrator", icon: "illustrator" },
  { name: "Tailwind CSS", icon: "tailwindcss" },
];
---

<section class="relative py-32 md:py-40 overflow-hidden bg-black">
  
  <!-- AMBIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/3 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[140px]"></div>
    <div class="absolute bottom-1/3 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[140px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <!-- HEADER -->
    <div class="text-center mb-20" data-reveal>
      
      <!-- LABEL -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10 mb-6">
        <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M12.316 3.051a1 1 0 01.633 1.265l-4 12a1 1 0 11-1.898-.632l4-12a1 1 0 011.265-.633zM5.707 6.293a1 1 0 010 1.414L3.414 10l2.293 2.293a1 1 0 11-1.414 1.414l-3-3a1 1 0 010-1.414l3-3a1 1 0 011.414 0zm8.586 0a1 1 0 011.414 0l3 3a1 1 0 010 1.414l-3 3a1 1 0 11-1.414-1.414L16.586 10l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd" />
        </svg>
        <span class="text-white/70 text-sm font-medium">Tech Stack</span>
      </div>

      <!-- TITLE -->
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
          Tecnologías
        </span>
      </h2>

      <!-- SUBTITLE -->
      <p class="text-xl text-white/60 max-w-2xl mx-auto">
        Herramientas y lenguajes que domino para crear experiencias digitales
      </p>
    </div>

    <!-- SKILLS GRID -->
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-6" data-reveal data-delay="200">
      {skills.map((skill, index) => (
        <div 
          class="skill-card group relative"
          style={`animation-delay: ${index * 50}ms;`}
        >
          
          <!-- AMBIENT GLOW -->
          <div class="absolute -inset-2 bg-gradient-to-r from-purple-500/0 to-cyan-500/0 
                      group-hover:from-purple-500/20 group-hover:to-cyan-500/20 
                      rounded-2xl blur-xl opacity-0 group-hover:opacity-100 
                      transition-all duration-500 -z-10"></div>

          <!-- CARD -->
          <div class="relative flex flex-col items-center justify-center p-6 rounded-2xl
                     bg-gradient-to-br from-white/10 to-white/5
                     backdrop-blur-xl border border-white/10
                     shadow-[0_8px_32px_rgba(0,0,0,0.2)]
                     hover:shadow-[0_20px_60px_rgba(0,0,0,0.3)]
                     hover:border-white/20
                     transition-all duration-500
                     hover:-translate-y-2 hover:scale-105
                     cursor-pointer">
            
            <!-- ICON CONTAINER -->
            <div class="relative mb-3">
              <!-- ICON GLOW -->
              <div class="absolute inset-0 bg-white/20 rounded-full blur-lg 
                          opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              
              <!-- ICON -->
              <img
                src={`https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${skill.icon}/${skill.icon}-original.svg`}
                alt={skill.name}
                class="relative w-12 h-12 md:w-14 md:h-14
                       transition-transform duration-500
                       group-hover:scale-110 group-hover:rotate-3"
                loading="lazy"
              />
            </div>

            <!-- NAME -->
            <p class="text-white/80 text-sm md:text-base font-semibold text-center
                     group-hover:text-white
                     transition-colors duration-300">
              {skill.name}
            </p>

            <!-- DECORATIVE DOT -->
            <div class="absolute top-2 right-2 w-2 h-2 rounded-full
                       bg-gradient-to-r from-purple-400 to-cyan-400
                       opacity-0 group-hover:opacity-100
                       transition-opacity duration-500"></div>

          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  /* Skill card reveal animation */
  .skill-card {
    opacity: 0;
    transform: translateY(20px);
  }

  .skill-card.show {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Reveal animations */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-delay="200"].revealed {
    transition-delay: 0.2s;
  }

  /* Typography */
  h2, p, span {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Intersection Observer for main sections
  const mainObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          mainObserver.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.2,
      rootMargin: '0px 0px -100px 0px'
    }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    mainObserver.observe(el);
  });

  // Intersection Observer for skill cards with stagger
  const skillsObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry, index) => {
        if (entry.isIntersecting) {
          setTimeout(() => {
            entry.target.classList.add('show');
          }, index * 50); // 50ms stagger
        }
      });
    },
    { 
      threshold: 0.15,
      rootMargin: '0px 0px -50px 0px'
    }
  );

  document.querySelectorAll('.skill-card').forEach((card) => {
    skillsObserver.observe(card);
  });
</script>