---
// Data
import { jobs } from "../../data/jobsData";
---

<section class="relative py-32 md:py-40 overflow-hidden bg-black">
  
  <!-- AMBIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[140px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[140px]"></div>
  </div>

  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <!-- HEADER -->
    <div class="text-center md:text-left mb-20" data-reveal>
      
      <!-- LABEL -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10 mb-6">
        <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6 6V5a3 3 0 013-3h2a3 3 0 013 3v1h2a2 2 0 012 2v3.57A22.952 22.952 0 0110 13a22.95 22.95 0 01-8-1.43V8a2 2 0 012-2h2zm2-1a1 1 0 011-1h2a1 1 0 011 1v1H8V5zm1 5a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1z" clip-rule="evenodd" />
          <path d="M2 13.692V16a2 2 0 002 2h12a2 2 0 002-2v-2.308A24.974 24.974 0 0110 15c-2.796 0-5.487-.46-8-1.308z" />
        </svg>
        <span class="text-white/70 text-sm font-medium">Experience</span>
      </div>

      <!-- TITLE -->
      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight">
        <span class="bg-gradient-to-r from-white to-white/40 bg-clip-text text-transparent">
          My
        </span>
        <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent ml-4">
          Experience
        </span>
      </h2>
    </div>

    <!-- TABS & CONTENT -->
    <div class="grid md:grid-cols-[240px_1fr] gap-8 md:gap-12" data-reveal data-delay="200">
      
      <!-- TABS SIDEBAR -->
      <div class="relative">
        <!-- MOBILE: Horizontal Scroll -->
        <div class="md:hidden flex gap-2 overflow-x-auto pb-2">
          {jobs.map((job, index) => (
            <button
              class={`tab-button flex-shrink-0 px-6 py-3 rounded-full
                     text-sm font-semibold whitespace-nowrap
                     transition-all duration-300
                     ${index === 0 
                       ? 'bg-white/10 backdrop-blur-xl border border-white/20 text-white' 
                       : 'bg-white/5 backdrop-blur-xl border border-white/10 text-white/60 hover:text-white hover:bg-white/10'
                     }`}
              data-index={index}
              aria-selected={index === 0 ? "true" : "false"}
            >
              {job.title}
            </button>
          ))}
        </div>

        <!-- DESKTOP: Vertical Stack -->
        <div class="hidden md:flex flex-col gap-2">
          {jobs.map((job, index) => (
            <button
              class={`tab-button relative text-left px-6 py-4 rounded-2xl
                     text-base font-semibold
                     transition-all duration-300
                     ${index === 0 
                       ? 'bg-white/10 backdrop-blur-xl border border-white/20 text-white' 
                       : 'bg-white/5 backdrop-blur-xl border border-white/10 text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20'
                     }`}
              data-index={index}
              aria-selected={index === 0 ? "true" : "false"}
            >
              {job.title}
            </button>
          ))}
        </div>
      </div>

      <!-- CONTENT PANELS -->
      <div class="relative min-h-[400px]">
        {jobs.map(({ title, time, description, list }, index) => (
          <div
            class={`tab-content ${index === 0 ? 'active' : ''}`}
            data-index={index}
          >
            <div class="rounded-3xl
                       bg-gradient-to-br from-white/10 to-white/5
                       backdrop-blur-xl border border-white/10
                       p-8 md:p-10
                       shadow-[0_8px_32px_rgba(0,0,0,0.2)]">
              
              <!-- JOB TITLE -->
              <h3 class="text-3xl md:text-4xl font-bold mb-4">
                <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
                  {title}
                </span>
              </h3>

              <!-- TIME BADGES -->
              <div class="flex flex-wrap gap-3 mb-6">
                {time.map((t) => (
                  <time 
                    class="px-4 py-2 rounded-full
                           bg-white/5 backdrop-blur-xl border border-white/10
                           text-white/70 text-sm font-medium"
                    datetime={t}
                  >
                    {t}
                  </time>
                ))}
              </div>

              <!-- DESCRIPTION -->
              <p class="text-white/70 text-base md:text-lg leading-relaxed mb-6">
                {description}
              </p>

              <!-- DIVIDER -->
              <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-6"></div>

              <!-- LIST -->
              <ul class="space-y-3">
                {list.map((item) => (
                  <li class="flex items-start gap-3 text-white/70 text-base leading-relaxed">
                    <!-- BULLET -->
                    <span class="flex-shrink-0 w-2 h-2 rounded-full bg-gradient-to-r from-purple-400 to-cyan-400 mt-2"></span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>

            </div>
          </div>
        ))}
      </div>

    </div>

  </div>
</section>

<style>
  /* Tab Content - Hidden by default */
  .tab-content {
    display: none;
    opacity: 0;
    animation: fadeIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Reveal animations */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-delay="200"].revealed {
    transition-delay: 0.2s;
  }

  /* Typography */
  h2, h3, p, span, button, time {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Scrollbar para móvil */
  @media (max-width: 768px) {
    .overflow-x-auto::-webkit-scrollbar {
      height: 4px;
    }

    .overflow-x-auto::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 2px;
    }

    .overflow-x-auto::-webkit-scrollbar-thumb {
      background: rgba(255, 255, 255, 0.2);
      border-radius: 2px;
    }
  }
</style>

<script>
  function initExperienceTabs() {
    const buttons = document.querySelectorAll('.tab-button');
    const contents = document.querySelectorAll('.tab-content');

    buttons.forEach((button) => {
      button.addEventListener('click', () => {
        const index = (button as HTMLElement).dataset.index;

        // Update buttons
        buttons.forEach((btn) => {
          btn.classList.remove('bg-white/10', 'border-white/20', 'text-white');
          btn.classList.add('bg-white/5', 'border-white/10', 'text-white/60');
          btn.setAttribute('aria-selected', 'false');
        });

        button.classList.remove('bg-white/5', 'border-white/10', 'text-white/60');
        button.classList.add('bg-white/10', 'border-white/20', 'text-white');
        button.setAttribute('aria-selected', 'true');

        // Update content
        contents.forEach((content) => {
          content.classList.remove('active');
        });

        const activeContent = document.querySelector(`.tab-content[data-index="${index}"]`);
        if (activeContent) {
          activeContent.classList.add('active');
        }
      });
    });
  }

  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.2,
      rootMargin: '0px 0px -100px 0px'
    }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    observer.observe(el);
  });

  // Init tabs
  initExperienceTabs();
  document.addEventListener('astro:after-swap', initExperienceTabs);
</script>