---
// Acordeón de FAQ en Astro + JS nativo (antes eran dos islas de React).
export interface FaqItem {
  icon: "code" | "briefcase" | "academic" | "team" | "agile";
  question: string;
  answer: string;
}

export interface Props {
  titleTop: string;
  titleBottom: string;
  subtitle: string;
  items: FaqItem[];
}

const { titleTop, titleBottom, subtitle, items } = Astro.props;

const icons = {
  code: "M3 6a3 3 0 013-3h12a3 3 0 013 3v12a3 3 0 01-3 3H6a3 3 0 01-3-3V6zm14.25 6a.75.75 0 01-.22.53l-2.25 2.25a.75.75 0 11-1.06-1.06L15.44 12l-1.72-1.72a.75.75 0 111.06-1.06l2.25 2.25c.141.14.22.331.22.53zm-10.28-.53a.75.75 0 000 1.06l2.25 2.25a.75.75 0 101.06-1.06L8.56 12l1.72-1.72a.75.75 0 10-1.06-1.06l-2.25 2.25z",
  briefcase: "M7.5 5.25a3 3 0 013-3h3a3 3 0 013 3V6h4.5A1.5 1.5 0 0122.5 7.5v12a1.5 1.5 0 01-1.5 1.5H3a1.5 1.5 0 01-1.5-1.5v-12A1.5 1.5 0 013 6h4.5v-.75zm3-1.5a1.5 1.5 0 00-1.5 1.5V6h3v-.75a1.5 1.5 0 00-1.5-1.5h-3z",
  academic: "M11.7 2.805a.75.75 0 01.6 0A60.65 60.65 0 0122.83 8.72a.75.75 0 01-.231 1.337 49.949 49.949 0 00-9.902 3.912l-.003.002-.34.18a.75.75 0 01-.707 0A50.009 50.009 0 007.5 12.174v-.224c0-.131.067-.248.172-.311a54.614 54.614 0 014.653-2.52.75.75 0 00-.65-1.352 56.129 56.129 0 00-4.78 2.589 1.858 1.858 0 00-.859 1.228 49.803 49.803 0 00-4.634-1.527.75.75 0 01-.231-1.337A60.653 60.653 0 0111.7 2.805z",
  team: "M4.5 6.375a4.125 4.125 0 118.25 0 4.125 4.125 0 01-8.25 0zM14.25 8.625a3.375 3.375 0 116.75 0 3.375 3.375 0 01-6.75 0zM1.5 19.125a7.125 7.125 0 0114.25 0v.003l-.001.119a.75.75 0 01-.363.63 13.067 13.067 0 01-6.761 1.873c-2.472 0-4.786-.684-6.76-1.873a.75.75 0 01-.364-.63l-.001-.122zM17.25 19.128l-.001.144a2.25 2.25 0 01-.233.96 10.088 10.088 0 005.06-1.01.75.75 0 00.42-.643 4.875 4.875 0 00-6.957-4.611 8.586 8.586 0 011.71 5.157v.003z",
  agile: "M2.625 6.75a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0zm4.875 0A.75.75 0 018.25 6h12a.75.75 0 010 1.5h-12a.75.75 0 01-.75-.75zM2.625 12a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0zM7.5 12a.75.75 0 01.75-.75h12a.75.75 0 010 1.5h-12A.75.75 0 017.5 12zm-4.875 5.25a1.125 1.125 0 112.25 0 1.125 1.125 0 01-2.25 0zm4.875 0a.75.75 0 01.75-.75h12a.75.75 0 010 1.5h-12a.75.75 0 01-.75-.75z",
};
---

<section class="relative py-32 md:py-40 px-6 overflow-hidden bg-black">
  <!-- AMBIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="ambient-blob absolute top-1/3 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full"></div>
    <div class="ambient-blob absolute bottom-1/3 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full"></div>
  </div>

  <div class="mx-auto w-full max-w-4xl">
    <!-- HEADER -->
    <div class="text-center mb-20">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 mb-6"
      >
        <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
          <path
            fill-rule="evenodd"
            d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z"
            clip-rule="evenodd"></path>
        </svg>
        <span class="text-white/70 text-sm font-medium">FAQ</span>
      </div>

      <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6">
        <span class="bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">
          {titleTop}
        </span>
        <br />
        <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
          {titleBottom}
        </span>
      </h2>

      <p class="text-xl text-white/60 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <!-- ACCORDION -->
    <ul class="space-y-4">
      {
        items.map((item, i) => (
          <li class="w-full">
            <div class="faq-card opacity-0 translate-y-8">
              <div
                class="faq-shell relative overflow-hidden rounded-3xl
                       bg-gradient-to-br from-white/10 to-white/5
                       border border-white/10
                       shadow-[0_8px_32px_rgba(0,0,0,0.2)]
                       transition-colors duration-300
                       hover:border-white/20"
              >
                <button
                  type="button"
                  class="faq-trigger flex items-center gap-4 p-6 md:p-8 w-full text-left group"
                  aria-expanded="false"
                  aria-controls={`faq-panel-${i}`}
                >
                  <div
                    class="faq-icon flex-shrink-0 p-3 rounded-2xl bg-white/5 border border-white/10
                           transition-transform duration-300 group-hover:bg-white/10"
                  >
                    <svg
                      viewBox="0 0 24 24"
                      fill="currentColor"
                      class="h-6 w-6 text-white/70"
                      aria-hidden="true"
                    >
                      <path d={icons[item.icon]} />
                    </svg>
                  </div>

                  <div class="flex grow items-center justify-between">
                    <span class="faq-question text-lg md:text-xl font-semibold text-white transition-colors duration-300">
                      {item.question}
                    </span>

                    <div class="faq-chevron flex-shrink-0 p-2 rounded-xl bg-white/5 border border-white/10 transition-transform duration-300">
                      <svg viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 text-white/70">
                        <path d="M12 14L6 8H18L12 14Z" />
                      </svg>
                    </div>
                  </div>
                </button>

                <div id={`faq-panel-${i}`} class="faq-panel" hidden>
                  <div class="px-6 md:px-8 pb-6 md:pb-8">
                    <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-6" />
                    <p class="text-white/70 text-base md:text-lg leading-relaxed">{item.answer}</p>
                  </div>
                </div>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  /* Blobs: blur estático y contenido, mucho más barato que blur-[140px] animado */
  .ambient-blob {
    filter: blur(120px);
    will-change: auto;
  }

  /* Entrada de las tarjetas */
  .faq-card {
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-card.show-card {
    opacity: 1;
    transform: translateY(0);
  }

  /* Panel: animado con grid-template-rows -> sin max-height "mágico" ni saltos */
  .faq-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .faq-panel > div {
    overflow: hidden;
    min-height: 0;
  }

  .faq-panel[data-open] {
    grid-template-rows: 1fr;
  }

  /* Estado abierto */
  .faq-shell[data-open] {
    border-color: rgba(255, 255, 255, 0.2);
  }

  .faq-shell[data-open] .faq-chevron {
    transform: rotate(180deg);
  }

  .faq-shell[data-open] .faq-icon {
    transform: scale(1.08);
  }

  .faq-shell[data-open] .faq-question {
    color: transparent;
    background-image: linear-gradient(to right, #c084fc, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
  }

  h2,
  p,
  span,
  button {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-card,
    .faq-panel,
    .faq-chevron,
    .faq-icon {
      transition: none;
    }
    .faq-card {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  function initFaq(root: ParentNode = document) {
    const triggers = root.querySelectorAll<HTMLButtonElement>(".faq-trigger");

    triggers.forEach((trigger) => {
      if (trigger.dataset.bound) return;
      trigger.dataset.bound = "1";

      trigger.addEventListener("click", () => {
        const shell = trigger.closest<HTMLElement>(".faq-shell");
        const panel = shell?.querySelector<HTMLElement>(".faq-panel");
        if (!shell || !panel) return;

        const isOpen = shell.hasAttribute("data-open");

        // Cierra los demás del mismo bloque
        const list = trigger.closest("ul");
        list?.querySelectorAll<HTMLElement>(".faq-shell[data-open]").forEach((other) => {
          if (other === shell) return;
          other.removeAttribute("data-open");
          const p = other.querySelector<HTMLElement>(".faq-panel");
          p?.removeAttribute("data-open");
          if (p) p.hidden = true;
          other.querySelector(".faq-trigger")?.setAttribute("aria-expanded", "false");
        });

        if (isOpen) {
          shell.removeAttribute("data-open");
          panel.removeAttribute("data-open");
          trigger.setAttribute("aria-expanded", "false");
          // Espera a la transición antes de ocultarlo del árbol de accesibilidad
          setTimeout(() => {
            if (!shell.hasAttribute("data-open")) panel.hidden = true;
          }, 450);
        } else {
          panel.hidden = false;
          // Fuerza un reflow para que la transición arranque desde 0fr
          void panel.offsetHeight;
          shell.setAttribute("data-open", "");
          panel.setAttribute("data-open", "");
          trigger.setAttribute("aria-expanded", "true");
        }
      });
    });

    // Entrada escalonada de las tarjetas
    const cards = root.querySelectorAll<HTMLElement>(".faq-card");
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry, i) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          setTimeout(() => el.classList.add("show-card"), i * 90);
          observer.unobserve(el);
        });
      },
      { threshold: 0.15, rootMargin: "0px 0px -50px 0px" }
    );

    cards.forEach((card) => observer.observe(card));
  }

  initFaq();
  document.addEventListener("astro:after-swap", () => initFaq());
</script>
