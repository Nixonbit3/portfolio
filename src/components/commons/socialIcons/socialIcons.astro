---
// Iconos sociales estáticos: se renderizan en el servidor, sin JS en el cliente.
import { FaXTwitter, FaLinkedinIn, FaGithub, FaItchIo } from "react-icons/fa6";
import { SiSketchfab } from "react-icons/si";

const links = [
  { href: "https://www.linkedin.com/in/nixon-correa-818388244/", label: "LinkedIn", Icon: FaLinkedinIn },
  { href: "https://github.com/Nixonbit3", label: "GitHub", Icon: FaGithub },
  { href: "https://x.com/nixon_correa3/", label: "Twitter", Icon: FaXTwitter },
  { href: "https://nixonbit3.itch.io/", label: "Itch.io", Icon: FaItchIo },
  { href: "https://sketchfab.com/nixoncorrea", label: "Sketchfab", Icon: SiSketchfab },
];
---

<div class="my-5 flex items-center justify-center gap-6">
  {
    links.map(({ href, label, Icon }) => (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={label}
        class="text-zinc-400 hover:text-[#69c7c7] drop-shadow-[1px_1px_0_#7836cf] transition-colors duration-300"
      >
        <Icon className="h-7 w-7" />
      </a>
    ))
  }
</div>
