---
import { HiArrowRight } from "react-icons/hi";

export interface Props {
  titulo: string;
  imagen: string;
  tecnologias: string[];
  demo: string;
  codigo?: string; // Ahora es opcional
}

const { titulo, imagen, tecnologias, demo, codigo } = Astro.props;
---

<article
  class="project-card group relative"
  data-reveal
>
  <!-- AMBIENT GLOW (appears on hover) -->
  <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/0 to-cyan-500/0 
              group-hover:from-purple-500/20 group-hover:to-cyan-500/20 
              rounded-3xl blur-2xl opacity-0 group-hover:opacity-100 
              transition-all duration-700 -z-10"></div>

  <!-- CARD CONTAINER -->
  <div class="relative h-full flex flex-col overflow-hidden rounded-3xl
              bg-gradient-to-br from-white/10 to-white/5
              backdrop-blur-xl border border-white/10
              shadow-[0_8px_32px_rgba(0,0,0,0.3)]
              hover:shadow-[0_20px_60px_rgba(0,0,0,0.4)]
              hover:border-white/20
              transition-all duration-700 ease-out
              hover:-translate-y-2">

    <!-- IMAGE SECTION -->
    <div class="relative overflow-hidden bg-black/20">
      <!-- IMAGE -->
      <div class="aspect-video w-full overflow-hidden">
        <img
          src={imagen}
          alt={`Proyecto: ${titulo}`}
          class="w-full h-full object-cover 
                 transition-all duration-700 ease-out
                 group-hover:scale-110"
        />
      </div>

      <!-- GRADIENT OVERLAY -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent 
                  opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

      <!-- QUICK ACTIONS (visible on hover) -->
      <div class="absolute top-4 right-4 flex gap-2 
                  opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 
                  transition-all duration-500">
        <a
          href={demo}
          target="_blank"
          class="p-2.5 rounded-xl bg-white/10 backdrop-blur-xl border border-white/20
                 hover:bg-white/20 hover:scale-110 active:scale-95
                 transition-all duration-300"
          aria-label="Ver demo"
        >
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </a>
        
        {codigo && (
          <a
            href={codigo}
            target="_blank"
            class="p-2.5 rounded-xl bg-white/10 backdrop-blur-xl border border-white/20
                   hover:bg-white/20 hover:scale-110 active:scale-95
                   transition-all duration-300"
            aria-label="Ver código"
          >
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </a>
        )}
      </div>
    </div>

    <!-- CONTENT SECTION -->
    <div class="flex flex-col flex-grow p-6 md:p-8">
      
      <!-- TITLE -->
      <h3 class="text-xl md:text-2xl font-bold text-white mb-4 
                 group-hover:text-transparent group-hover:bg-gradient-to-r 
                 group-hover:from-purple-400 group-hover:to-cyan-400 
                 group-hover:bg-clip-text transition-all duration-500">
        {titulo}
      </h3>

      <!-- TECH STACK -->
      <div class="flex flex-wrap gap-2 mb-6">
        {tecnologias.map((tech) => (
          <span class="px-3 py-1.5 rounded-lg 
                       bg-white/5 backdrop-blur-xl border border-white/10
                       text-white/70 text-xs font-medium
                       hover:bg-white/10 hover:text-white hover:border-white/20
                       transition-all duration-300">
            {tech}
          </span>
        ))}
      </div>

      <!-- DIVIDER -->
      <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-6"></div>

      <!-- ACTION BUTTONS -->
      <div class={`mt-auto grid gap-3 ${codigo ? 'grid-cols-2' : 'grid-cols-1'}`}>
        <a
          href={demo}
          target="_blank"
          class="group/btn flex items-center justify-center gap-2 px-4 py-3 rounded-xl
                 bg-white text-black font-semibold text-sm
                 hover:scale-105 active:scale-95
                 transition-all duration-300
                 shadow-lg hover:shadow-xl"
        >
          <span>Demo</span>
          <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:translate-x-0.5" 
               fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>

        {codigo && (
          <a
            href={codigo}
            target="_blank"
            class="group/btn flex items-center justify-center gap-2 px-4 py-3 rounded-xl
                   bg-white/5 backdrop-blur-xl border border-white/20
                   text-white font-semibold text-sm
                   hover:bg-white/10 hover:border-white/30
                   hover:scale-105 active:scale-95
                   transition-all duration-300"
          >
            <span>Código</span>
            <svg class="w-4 h-4 transition-transform duration-300 group-hover/btn:rotate-12" 
                 fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        )}
      </div>

    </div>
  </div>
</article>

<style>
  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Typography */
  h3, span {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  /* Ensure smooth transforms */
  .project-card {
    will-change: transform;
  }
</style>