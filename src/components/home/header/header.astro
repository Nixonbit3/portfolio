---
import SocialIcons from "../../commons/socialIcons/socialIcons.jsx";
import TypeEfect from "../header/typeEfect.jsx";
---

<header class="relative min-h-screen bg-black overflow-hidden">
  <!-- MESH GRADIENT BACKGROUND -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,54,207,0.15),transparent)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_80%_50%,rgba(0,255,242,0.08),transparent)]"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </div>

  <!-- GRID PATTERN (OPTIONAL) -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,black,transparent)]"></div>

  <main class="relative z-10 flex flex-col items-center justify-center min-h-screen text-center px-6 md:px-8">
    <!-- BADGE LABEL -->
    <div 
      class="mb-6 inline-flex items-center gap-2 px-4 py-1.5 rounded-full 
             bg-white/5 backdrop-blur-xl border border-white/10
             opacity-0 translate-y-4 animate-fadeIn"
      style="animation-delay: 0.1s;"
    >
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-white/70 text-sm font-medium">Disponible para proyectos</span>
    </div>

    <!-- MAIN HEADING -->
    <h1 
      class="text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-bold tracking-tight
             opacity-0 translate-y-8 animate-fadeIn"
      style="animation-delay: 0.2s;"
    >
      <span class="bg-gradient-to-b from-white via-white to-white/40 bg-clip-text text-transparent">
        Hola, soy
      </span>
      <br />
      <span class="bg-gradient-to-r from-purple-400 via-fuchsia-400 to-cyan-400 bg-clip-text text-transparent">
        Nixon
      </span>
    </h1>

    <!-- TYPEWRITER EFFECT -->
    <div 
      class="mt-8 opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.4s;"
    >
      <TypeEfect client:visible />
    </div>

    <!-- DESCRIPTION -->
    <p 
      class="mt-8 text-lg md:text-xl text-white/60 max-w-2xl font-normal leading-relaxed
             opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.6s;"
    >
      Explora mis proyectos, conoce un poco más sobre mí y, si deseas ponerte en contacto, 
      <span class="text-white/80">¡estoy a solo un mensaje de distancia!</span>
    </p>

    <!-- SOCIAL ICONS -->
    <div 
      class="mt-10 opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.8s;"
    >
      <SocialIcons client:visible />
    </div>

    <!-- CTA BUTTON -->
    <a
      target="_blank"
      href="/contact"
      class="group mt-10 relative inline-flex items-center justify-center px-8 py-4
             bg-white text-black font-semibold rounded-full
             transition-all duration-300 ease-out
             hover:scale-105 hover:shadow-[0_20px_60px_-15px_rgba(255,255,255,0.3)]
             active:scale-95
             opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 1s;"
    >
      <span class="relative z-10">Contactar</span>
      <svg 
        class="ml-2 w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" 
        fill="none" 
        viewBox="0 0 24 24" 
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
      
      <!-- GLOW EFFECT -->
      <div class="absolute inset-0 rounded-full bg-white opacity-0 group-hover:opacity-20 blur-xl transition-opacity duration-300"></div>
    </a>

    <!-- SCROLL INDICATOR -->
    <div 
      class="absolute bottom-12 left-1/2 -translate-x-1/2
             opacity-0 animate-fadeIn"
      style="animation-delay: 1.2s;"
    >
      <div class="flex flex-col items-center gap-2">
        <span class="text-white/40 text-sm font-medium">Scroll para explorar</span>
        <div class="w-6 h-10 rounded-full border-2 border-white/20 flex items-start justify-center p-2">
          <div class="w-1.5 h-3 bg-white/60 rounded-full animate-scroll-down"></div>
        </div>
      </div>
    </div>

  </main>
</header>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollDown {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  .animate-fadeIn {
    animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-scroll-down {
    animation: scrollDown 1.5s ease-in-out infinite;
  }

  /* SF Pro Text simulation with system fonts */
  h1, p, span {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", "Helvetica Neue", sans-serif;
    letter-spacing: -0.02em;
  }

  /* Smooth text rendering */
  h1 {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>