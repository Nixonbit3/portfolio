---
import SocialIcons from "../../commons/socialIcons/socialIcons.astro";

// Roles del efecto de tipeo (no se traducen: son términos del sector)
const roles = [
  "Unity Developer",
  "Gameplay Programmer",
  "Mobile Game Developer",
  "C# Developer",
];
---

<header class="relative min-h-screen bg-black overflow-hidden">
  <!-- MESH GRADIENT BACKGROUND -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,54,207,0.15),transparent)]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_60%_at_80%_50%,rgba(0,255,242,0.08),transparent)]"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
  </div>

  <!-- GRID PATTERN (OPTIONAL) -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:72px_72px] [mask-image:radial-gradient(ellipse_80%_50%_at_50%_0%,black,transparent)]"></div>

  <main class="relative z-10 flex flex-col items-center justify-center min-h-screen text-center px-6 md:px-8">
    <!-- BADGE LABEL -->
    <div 
      class="mb-6 inline-flex items-center gap-2 px-4 py-1.5 rounded-full 
             bg-white/5 backdrop-blur-xl border border-white/10
             opacity-0 translate-y-4 animate-fadeIn"
      style="animation-delay: 0.1s;"
    >
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span class="text-white/70 text-sm font-medium">Looking for my first role · Barcelona or remote</span>
    </div>

    <!-- MAIN HEADING -->
    <h1 
      class="text-5xl sm:text-6xl md:text-8xl lg:text-9xl font-bold tracking-tight
             opacity-0 translate-y-8 animate-fadeIn"
      style="animation-delay: 0.2s;"
    >
      <span class="bg-gradient-to-b from-white via-white to-white/40 bg-clip-text text-transparent">
        Hi, I'm
      </span>
      <br />
      <span class="bg-gradient-to-r from-purple-400 via-fuchsia-400 to-cyan-400 bg-clip-text text-transparent">
        Nixon
      </span>
    </h1>

    <!-- TYPEWRITER EFFECT -->
    <div 
      class="mt-8 opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.4s;"
    >
      <div class="notranslate mt-5 text-3xl font-bold" aria-live="off">
        <span id="role-text" data-roles={JSON.stringify(roles)}>{roles[0]}</span><span
          class="role-caret"
          aria-hidden="true">|</span>
      </div>
    </div>

    <!-- DESCRIPTION -->
    <p 
      class="mt-8 text-lg md:text-xl text-white/60 max-w-2xl font-normal leading-relaxed
             opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.6s;"
    >
      Junior Unity Developer focused on gameplay and mobile games. I just shipped my first Android game, built end-to-end with Unity and C#.
      <span class="text-white/80">Shall we talk?</span>
    </p>

    <!-- SOCIAL ICONS -->
    <div 
      class="mt-10 opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 0.8s;"
    >
      <SocialIcons />
    </div>

    <!-- CTA BUTTONS -->
    <div
      class="mt-10 flex flex-col sm:flex-row items-center gap-4
             opacity-0 translate-y-6 animate-fadeIn"
      style="animation-delay: 1s;"
    >
      <!-- PRIMARIO: probar el juego publicado (lo mas convincente para un estudio) -->
      <a
        href="https://nixonbit3.itch.io/air-bomb"
        target="_blank"
        rel="noopener noreferrer"
        class="group relative inline-flex items-center justify-center px-8 py-4 w-full sm:w-auto
               bg-white text-black font-semibold rounded-full
               transition-transform duration-300 ease-out
               hover:scale-105 active:scale-95
               shadow-lg hover:shadow-[0_20px_60px_-15px_rgba(255,255,255,0.35)]"
      >
        <span class="mr-2 text-xl" aria-hidden="true">🎮</span>
        <span>Play Air Bomb</span>
        <svg
          class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>

      <!-- SECUNDARIO: contacto -->
      <a
        href="/contact"
        class="group inline-flex items-center justify-center px-8 py-4 w-full sm:w-auto
               bg-white/5 border border-white/20 text-white font-semibold rounded-full
               transition-colors duration-300
               hover:bg-white/10 hover:border-white/30"
      >
        <span>Contact</span>
        <svg
          class="ml-2 w-5 h-5 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- SCROLL INDICATOR -->
    <!-- pointer-events-none: es decoracion y se superpone a los botones del
         hero en pantallas bajas; sin esto robaba los clics del CTA. -->
    <div
      class="absolute bottom-12 left-1/2 -translate-x-1/2
             pointer-events-none select-none
             opacity-0 animate-fadeIn"
      style="animation-delay: 1.2s;"
      aria-hidden="true"
    >
      <div class="flex flex-col items-center gap-2">
        <span class="text-white/40 text-sm font-medium">Scroll to explore</span>
        <div class="w-6 h-10 rounded-full border-2 border-white/20 flex items-start justify-center p-2">
          <div class="w-1.5 h-3 bg-white/60 rounded-full animate-scroll-down"></div>
        </div>
      </div>
    </div>

  </main>
</header>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes scrollDown {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    100% {
      transform: translateY(12px);
      opacity: 0;
    }
  }

  .animate-fadeIn {
    animation: fadeIn 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .animate-scroll-down {
    animation: scrollDown 1.5s ease-in-out infinite;
  }

  /* Cursor del efecto de tipeo */
  @keyframes caretBlink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .role-caret {
    animation: caretBlink 1s step-end infinite;
  }

  /* Respeta a quien prefiere menos movimiento */
  @media (prefers-reduced-motion: reduce) {
    .animate-fadeIn,
    .animate-scroll-down,
    .role-caret {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* SF Pro Text simulation with system fonts */
  h1, p, span {
    letter-spacing: -0.02em;
  }

  /* Smooth text rendering */
  h1 {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Efecto de tipeo nativo (sustituye a typewriter-effect + React: ~213 KB menos)
  const el = document.getElementById("role-text");

  if (el) {
    const roles: string[] = JSON.parse(el.dataset.roles || "[]");
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (roles.length && !reduced) {
      let index = 0;
      let chars = roles[0].length;
      let deleting = true;
      let timer: ReturnType<typeof setTimeout>;

      const tick = () => {
        const word = roles[index];
        chars += deleting ? -1 : 1;
        el.textContent = word.slice(0, chars);

        let delay = deleting ? 45 : 90;

        if (!deleting && chars === word.length) {
          delay = 1800;
          deleting = true;
        } else if (deleting && chars === 0) {
          deleting = false;
          index = (index + 1) % roles.length;
          delay = 300;
        }

        timer = setTimeout(tick, delay);
      };

      timer = setTimeout(tick, 1800);

      // Pausa cuando la pestaña no está visible (ahorra batería y evita saltos)
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          clearTimeout(timer);
        } else {
          clearTimeout(timer);
          timer = setTimeout(tick, 400);
        }
      });
    }
  }
</script>