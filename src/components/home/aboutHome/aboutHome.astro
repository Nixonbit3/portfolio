---
import { HiArrowRight } from "react-icons/hi";
import MiFoto from "../../../assets/img/MiFoto.png";
---

<section 
  class="relative py-32 md:py-40 overflow-hidden bg-black"
  data-section="about"
>

  <!-- AMBIENT GRADIENT BACKGROUND -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/10 rounded-full blur-[120px] animate-float"></div>
    <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-cyan-500/10 rounded-full blur-[120px] animate-float-delayed"></div>
  </div>

  <!-- SECTION CONTAINER -->
  <div class="mx-auto max-w-7xl px-6 md:px-8">
    
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- LEFT: IMAGE -->
      <div 
        class="relative order-2 md:order-1"
        data-reveal
      >
        <!-- DECORATIVE BACKGROUND ELEMENTS -->
        <div class="absolute -inset-4 bg-gradient-to-r from-purple-500/20 to-cyan-500/20 rounded-3xl blur-2xl opacity-50"></div>
        
        <div class="relative group">
          <!-- MAIN IMAGE CONTAINER -->
          <div 
            class="relative overflow-hidden rounded-3xl
                   bg-gradient-to-br from-white/10 to-white/5
                   backdrop-blur-xl border border-white/10
                   shadow-2xl shadow-black/50
                   transition-all duration-700 ease-out
                   hover:shadow-[0_40px_80px_-20px_rgba(120,54,207,0.4)]
                   hover:scale-[1.02]"
          >
            <img 
              src={MiFoto.src} 
              alt="Nixon - Game Developer"
              class="w-full h-auto object-cover
                     transition-all duration-700 ease-out
                     group-hover:scale-105"
            />
            
            <!-- GRADIENT OVERLAY ON HOVER -->
            <div class="absolute inset-0 bg-gradient-to-t from-purple-500/10 via-transparent to-transparent 
                        opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
          </div>

          <!-- FLOATING BADGE -->
          <div 
            class="absolute -bottom-6 -right-6 px-6 py-3 rounded-2xl
                   bg-white/10 backdrop-blur-2xl border border-white/20
                   shadow-xl
                   transform group-hover:translate-y-[-4px] transition-transform duration-500"
          >
            <div class="flex items-center gap-3">
              <div class="relative flex h-3 w-3">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-3 w-3 bg-emerald-500"></span>
              </div>
              <span class="text-white font-semibold text-sm">Disponible</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: CONTENT -->
      <div 
        class="order-1 md:order-2 space-y-8"
        data-reveal
        data-delay="200"
      >
        <!-- LABEL -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10">
          <svg class="w-4 h-4 text-purple-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"/>
          </svg>
          <span class="text-white/70 text-sm font-medium">Sobre mí</span>
        </div>

        <!-- HEADING -->
        <h2 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1]">
          <span class="bg-gradient-to-b from-white to-white/40 bg-clip-text text-transparent">
            Creando experiencias
          </span>
          <br />
          <span class="bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
            digitales únicas
          </span>
        </h2>

        <!-- DESCRIPTION -->
        <div class="space-y-6 text-lg md:text-xl text-white/60 leading-relaxed">
          <p>
            Soy <span class="text-white/90 font-semibold">Nixon</span>, desarrollador y diseñador de videojuegos 
            y experiencias digitales. Me apasiona crear interfaces, herramientas y juegos que 
            <span class="text-white/80">conectan visualmente con el usuario.</span>
          </p>
          
          <p>
            Trabajo con <span class="text-white/80">Unity, C#, React, Astro, Tailwind, Blender</span> y más.
            Me gusta convertir ideas en experiencias reales que impactan y entretienen.
          </p>
        </div>

        <!-- TECH STACK PILLS -->
        <div class="flex flex-wrap gap-3 pt-4">
          {["Unity", "C#", "React", "Blender", "Tailwind"].map((tech) => (
            <span class="px-4 py-2 rounded-full bg-white/5 backdrop-blur-xl border border-white/10
                         text-white/80 text-sm font-medium
                         hover:bg-white/10 hover:border-white/20 transition-all duration-300">
              {tech}
            </span>
          ))}
        </div>

        <!-- CTA BUTTON -->
        <div class="pt-4">
          <a
            href="/about"
            class="group inline-flex items-center gap-3 px-8 py-4 rounded-full
                   bg-gradient-to-r from-purple-500 to-cyan-500
                   text-white font-semibold
                   shadow-lg shadow-purple-500/25
                   hover:shadow-2xl hover:shadow-purple-500/40
                   hover:scale-105 active:scale-95
                   transition-all duration-300"
          >
            <span>Conocer más sobre mí</span>
            <HiArrowRight 
              className="transition-transform duration-300 group-hover:translate-x-1" 
              size={20}
            />
          </a>
        </div>

        <!-- Este bloque no se renderiza -->
        <!-- STATS -->
        <!-- <div class="grid grid-cols-3 gap-8 pt-8 border-t border-white/10"> 
          <div class="space-y-1">
            <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
              5+
            </div>
            <div class="text-sm text-white/50">Años de experiencia</div>
          </div>
          <div class="space-y-1">
            <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
              20+
            </div>
            <div class="text-sm text-white/50">Proyectos completados</div>
          </div>
          <div class="space-y-1">
            <div class="text-3xl font-bold bg-gradient-to-r from-purple-400 to-cyan-400 bg-clip-text text-transparent">
              100%
            </div>
            <div class="text-sm text-white/50">Dedicación</div>
          </div>
        </div>
         -->
      </div>

    </div>
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(30px, -30px);
    }
  }

  @keyframes floatDelayed {
    0%, 100% {
      transform: translate(0, 0);
    }
    50% {
      transform: translate(-30px, 30px);
    }
  }

  .animate-float {
    animation: float 20s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: floatDelayed 20s ease-in-out infinite;
    animation-delay: -10s;
  }

  /* Reveal animation */
  [data-reveal] {
    opacity: 0;
    transform: translateY(40px);
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
    transition: all 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-reveal][data-delay="200"].revealed {
    transition-delay: 0.2s;
  }

  /* Typography */
  h2, p, span {
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "SF Pro Text", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
</style>

<script>
  // Intersection Observer for reveal animations
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          observer.unobserve(entry.target);
        }
      });
    },
    { 
      threshold: 0.2,
      rootMargin: '0px 0px -100px 0px'
    }
  );

  document.querySelectorAll('[data-reveal]').forEach((el) => {
    observer.observe(el);
  });
</script>