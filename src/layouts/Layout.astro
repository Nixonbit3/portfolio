---
import "../styles/global.css";
import Navbar from "../components/commons/navbar/navbar.astro";
import Footer from "../components/commons/footer/footer.astro";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  /** Imagen de vista previa; ruta desde la raíz del sitio */
  image?: string;
}

const {
  title = "Nixon Correa — Junior Unity Developer",
  description =
    "Junior Unity Developer centrado en gameplay y juegos móviles. Autor de Air Bomb, shooter arcade publicado en Android. Barcelona o remoto.",
  noindex = false,
  image = "/og.jpg",
} = Astro.props;

const base = Astro.site ?? Astro.url;
const canonical = new URL(Astro.url.pathname, base);

// Las redes sociales exigen URL absoluta para la imagen de vista previa
const ogImage = new URL(image, base);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#000000" />

    <!-- Precarga de las fuentes: evita el parpadeo de texto al cargar -->
    <link
      rel="preload"
      href="/fonts/inter-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/space-grotesk-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonical} />

    <!-- Vista previa al compartir el enlace (email, LinkedIn, WhatsApp...) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Nixon Correa" />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Nixon Correa, Junior Unity Developer. Air Bomb, juego publicado en Android."
    />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="bg-gray-950 text-white">
    <Navbar />
    
    <!-- Padding SOLO en móvil -->
    <main class="pt-16 md:pt-0">
      <slot />
    </main>
    
    <Footer />

    <script>
      import "../scripts/i18n.js";
      import "../scripts/mail.js";
    </script>
  </body>
</html>