---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/commons/hero/hero.astro";
import AboutMe from "../components/about/aboutMe.astro";
import Experience from "../components/about/experience.astro";
import Features from "../components/about/features.astro";
import Skills from "../components/about/skills.astro";
import Faq from "../components/commons/faq/Faq.astro";
import { faqAbout } from "../data/faqData.js";
import BannerGithub from "../components/about/bannerGithub.astro";
import Banner from "../components/commons/banners/banner.astro";
---

<Layout
  title="Sobre mí - Nixon Correa"
  description="Conoce a Nixon Correa: desarrollador y diseñador de videojuegos graduado en el CITM (UPC). Experiencia, formación y habilidades."
>
  <Hero titulo="Sobre Mi" />
  <AboutMe />
  <Experience />
  <Features />
  <Skills />
  <Faq
    titleTop="Más sobre"
    titleBottom="mi trabajo"
    subtitle="Conoce más sobre mi experiencia, habilidades y forma de trabajo"
    items={faqAbout}
  />
  <BannerGithub />
  <Banner />
</Layout>
