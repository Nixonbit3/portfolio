---
import Layout from "../layouts/Layout.astro";
import Header from "../components/home/header/header.astro";
import Slider from "../components/home/header/slider.astro";
import AboutHome from "../components/home/aboutHome/aboutHome.astro";
import HomeProyect from "../components/home/homeProyect/homeProyect.astro";
import Faq from "../components/commons/faq/Faq.astro";
import { faqHome } from "../data/faqData.js";
import Banner from "../components/commons/banners/banner.astro";
---

<Layout>
  <Header />
  <Slider />
  <AboutHome />
  <HomeProyect />
  <Faq
    titleTop="About me"
    titleBottom="and my work"
    subtitle="Learn more about my experience, skills and way of working"
    items={faqHome}
  />
  <Banner />
</Layout>
