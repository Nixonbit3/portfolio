---
import Layout from "../layouts/Layout.astro";
import MailLink from "../components/commons/mail/MailLink.astro";

// CV en linea, optimizado para imprimir o guardar como PDF.
// Deliberadamente SIN datos sensibles: no hay telefono, ni direccion,
// ni DNI, ni fecha de nacimiento. El email va protegido contra bots.
// Texto comprimido a proposito: el CV debe caber en UNA pagina impresa.
const perfil = `Junior Unity Developer focused on gameplay and mobile. Shipped Air Bomb, an arcade shooter for Android, built solo end-to-end with Unity and C#. Video Game Design and Development graduate (CITM – UPC). Looking for a first role as Junior Unity / Gameplay Developer, in Barcelona or remote.`;

const experiencia = [
  {
    puesto: "IT Support Technician",
    empresa: "Col·legi d'Arquitectes de Catalunya (COAC)",
    lugar: "Barcelona",
    periodo: "Mar 2025 — Aug 2025",
    puntos: [
      "Designed gamified cybersecurity training for staff — applying game mechanics to real-world learning.",
      "Built interactive PDF forms and edited institutional videos to the organisation's standards.",
    ],
  },
];

const proyectos = [
  {
    nombre: "Air Bomb",
    tipo: "Shipped game · Android",
    enlace: "https://nixonbit3.itch.io/air-bomb",
    enlaceTexto: "nixonbit3.itch.io/air-bomb",
    puntos: [
      "Space Invaders-style arcade shooter, built solo end-to-end with Unity and C#.",
      "View/Controller architecture, data-driven levels with ScriptableObjects, event-based communication, DOTween, JSON persistence and cross-scene audio.",
    ],
  },
  {
    nombre: "Fracture Tool for Unity",
    tipo: "Final degree project",
    enlace: "https://github.com/Nixonbit3/FractureTool",
    enlaceTexto: "github.com/Nixonbit3/FractureTool",
    puntos: [
      "Real-time 3D fragmentation system as a Unity editor tool, written in C# with a focus on performance and usability.",
    ],
  },
  {
    nombre: "Realistic 3D Mate Gourd",
    tipo: "3D Art",
    enlace: "https://www.artstation.com/artwork/8wnkNQ",
    enlaceTexto: "artstation.com/artwork/8wnkNQ",
    puntos: ["Photorealistic modelling and texturing in Blender and Substance Painter."],
  },
];

const habilidades = [
  { grupo: "Engines & languages", items: "Unity, C#, C++, Unreal Engine, Python" },
  { grupo: "Gameplay & architecture", items: "ScriptableObjects, DOTween, data-driven design, event-driven architecture, JSON persistence" },
  { grupo: "Mobile", items: "Android builds, UI and HUD systems, testing on real devices" },
  { grupo: "Art, 3D & tools", items: "Blender, Maya, 3ds Max, Substance Painter, Photoshop, Figma, Git, Scrum / Kanban" },
];

const enlaces = [
  { etiqueta: "Portfolio", url: "https://nixondanielcorrea.netlify.app", texto: "nixondanielcorrea.netlify.app" },
  { etiqueta: "LinkedIn", url: "https://www.linkedin.com/in/nixon-correa", texto: "linkedin.com/in/nixon-correa" },
  { etiqueta: "GitHub", url: "https://github.com/Nixonbit3", texto: "github.com/Nixonbit3" },
  { etiqueta: "itch.io", url: "https://nixonbit3.itch.io", texto: "nixonbit3.itch.io" },
  { etiqueta: "Sketchfab", url: "https://sketchfab.com/nixoncorrea", texto: "sketchfab.com/nixoncorrea" },
];
---

<Layout
  title="Resume - Nixon Correa | Junior Unity Developer"
  description="Resume of Nixon Correa, Junior Unity Developer focused on gameplay and mobile games. Barcelona or remote."
>
  <div class="cv-page bg-black text-white">
    <!-- BARRA DE ACCIONES (no se imprime) -->
    <div class="no-print sticky top-16 md:top-20 z-40 border-b border-white/10 bg-black/80 backdrop-blur-xl">
      <div class="mx-auto max-w-4xl px-6 py-4 flex flex-wrap items-center justify-between gap-4">
        <p class="text-sm text-white/50">
          Resume view · use the button to save it as a PDF
        </p>
        <button
          id="print-cv"
          type="button"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
                 bg-white text-black font-semibold text-sm
                 hover:scale-105 active:scale-95 transition-transform duration-300"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
          Download PDF
        </button>
      </div>
    </div>

    <article class="cv mx-auto max-w-4xl px-6 py-14 md:py-20">
      <!-- CABECERA -->
      <header class="cv-header">
        <h1 class="cv-name">Nixon Correa</h1>
        <p class="cv-role">Junior Unity Developer · Gameplay &amp; Mobile</p>
        <p class="cv-location">Barcelona, Spain · Open to remote</p>

        <ul class="cv-links">
          <li>
            <span class="cv-link-label">Email</span>
            <MailLink encoded="bW9jLmxpYW1nQGFlcnJvY25kbg==" class="cv-link" />
          </li>
          {
            enlaces.map((e) => (
              <li>
                <span class="cv-link-label">{e.etiqueta}</span>
                <a class="cv-link" href={e.url} target="_blank" rel="noopener noreferrer">
                  {e.texto}
                </a>
              </li>
            ))
          }
        </ul>
      </header>

      <!-- PERFIL -->
      <section class="cv-section">
        <h2 class="cv-section-title">Profile</h2>
        <p class="cv-text">{perfil}</p>
      </section>

      <!-- EXPERIENCIA -->
      <section class="cv-section">
        <h2 class="cv-section-title">Experience</h2>
        {
          experiencia.map((e) => (
            <div class="cv-entry">
              <div class="cv-entry-head">
                <h3 class="cv-entry-title">{e.puesto}</h3>
                <span class="cv-entry-date">{e.periodo}</span>
              </div>
              <p class="cv-entry-sub">
                {e.empresa} · {e.lugar}
              </p>
              <ul class="cv-list">
                {e.puntos.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>

      <!-- PROYECTOS -->
      <section class="cv-section">
        <h2 class="cv-section-title">Projects</h2>
        {
          proyectos.map((p) => (
            <div class="cv-entry">
              <div class="cv-entry-head">
                <h3 class="cv-entry-title">{p.nombre}</h3>
                <span class="cv-entry-date">{p.tipo}</span>
              </div>
              <p class="cv-entry-sub">
                <a class="cv-link" href={p.enlace} target="_blank" rel="noopener noreferrer">
                  {p.enlaceTexto}
                </a>
              </p>
              <ul class="cv-list">
                {p.puntos.map((x) => (
                  <li>{x}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </section>

      <!-- FORMACIÓN -->
      <section class="cv-section">
        <h2 class="cv-section-title">Education</h2>
        <div class="cv-entry">
          <div class="cv-entry-head">
            <h3 class="cv-entry-title">BSc in Video Game Design and Development</h3>
            <span class="cv-entry-date">Sep 2021 — Jul 2025</span>
          </div>
          <p class="cv-entry-sub">
            Centre de la Imatge i la Tecnologia Multimèdia · CITM (UPC), Barcelona
          </p>
        </div>
      </section>

      <!-- HABILIDADES -->
      <section class="cv-section">
        <h2 class="cv-section-title">Skills</h2>
        <dl class="cv-skills">
          {
            habilidades.map((h) => (
              <div class="cv-skill-row">
                <dt>{h.grupo}</dt>
                <dd>{h.items}</dd>
              </div>
            ))
          }
        </dl>
      </section>
    </article>
  </div>
</Layout>

<style>
  /* ---------- Pantalla ---------- */
  .cv-header {
    padding-bottom: 1.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .cv-name {
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(to right, #fff, rgba(255, 255, 255, 0.6));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cv-role {
    margin-top: 0.6rem;
    font-size: 1.15rem;
    font-weight: 600;
    background: linear-gradient(to right, #c084fc, #22d3ee);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .cv-location {
    margin-top: 0.35rem;
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.55);
  }

  .cv-links {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.5rem 2rem;
    font-size: 0.9rem;
  }

  .cv-links li {
    display: flex;
    gap: 0.6rem;
    align-items: baseline;
  }

  .cv-link-label {
    color: rgba(255, 255, 255, 0.45);
    min-width: 4.6rem;
    font-weight: 500;
  }

  .cv-link {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    transition: border-color 0.25s ease, color 0.25s ease;
    overflow-wrap: anywhere;
  }

  .cv-link:hover {
    color: #fff;
    border-color: #22d3ee;
  }

  .cv-section {
    margin-top: 2.75rem;
  }

  .cv-section-title {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #22d3ee;
    margin-bottom: 1.1rem;
  }

  .cv-text {
    color: rgba(255, 255, 255, 0.72);
    max-width: 68ch;
  }

  .cv-entry + .cv-entry {
    margin-top: 1.6rem;
  }

  .cv-entry-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .cv-entry-title {
    font-size: 1.12rem;
    font-weight: 600;
    color: #fff;
  }

  .cv-entry-date {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .cv-entry-sub {
    margin-top: 0.2rem;
    font-size: 0.92rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .cv-list {
    margin-top: 0.7rem;
    display: grid;
    gap: 0.42rem;
  }

  .cv-list li {
    position: relative;
    padding-left: 1.1rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.95rem;
    max-width: 74ch;
  }

  .cv-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 99px;
    background: linear-gradient(to right, #c084fc, #22d3ee);
  }

  .cv-skills {
    display: grid;
    gap: 0.7rem;
  }

  .cv-skill-row {
    display: grid;
    grid-template-columns: minmax(0, 15rem) minmax(0, 1fr);
    gap: 0.3rem 1.5rem;
    align-items: baseline;
  }

  .cv-skill-row dt {
    font-weight: 600;
    color: #fff;
    font-size: 0.92rem;
  }

  .cv-skill-row dd {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
  }

  @media (max-width: 640px) {
    .cv-skill-row {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Impresión / PDF ----------
     Papel blanco, tinta negra, sin decoración y sin desperdiciar espacio. */
  @media print {
    @page {
      size: A4;
      margin: 11mm 13mm;
    }

    /* El CV entero debe caber en UNA hoja: tipografia y espaciados ajustados */
    :global(html) {
      font-size: 100%;
    }

    :global(html),
    :global(body) {
      background: #fff !important;
      color: #111 !important;
    }

    /* Fuera todo lo que no es el CV */
    :global(nav),
    :global(footer),
    .no-print {
      display: none !important;
    }

    :global(main) {
      padding: 0 !important;
    }

    .cv-page {
      background: #fff !important;
      color: #111 !important;
    }

    /* CLAVE para que salga en UNA pagina tambien desde el movil.
       Safari en iOS maqueta la impresion con el ancho de la pantalla del
       telefono (~375px), no con el del papel: el texto se parte en muchas
       mas lineas y el CV se iba a una segunda hoja.
       Fijando el ancho en milimetros (ancho util de un A4 menos margenes)
       el resultado es identico en movil y en escritorio. */
    .cv-page {
      width: 184mm !important;
    }

    .cv {
      width: 184mm !important;
      max-width: none !important;
      padding: 0 !important;
    }

    .cv-name {
      font-size: 24pt;
      background: none;
      -webkit-text-fill-color: #111;
      color: #111;
    }

    .cv-role {
      font-size: 11.5pt;
      background: none;
      -webkit-text-fill-color: #000;
      color: #000;
      margin-top: 1pt;
    }

    .cv-location {
      font-size: 8.5pt;
      margin-top: 1pt;
    }

    .cv-location,
    .cv-entry-date,
    .cv-entry-sub,
    .cv-link-label {
      color: #555 !important;
    }

    .cv-header {
      border-bottom: 1px solid #ccc;
      padding-bottom: 6pt;
    }

    /* Enlaces en linea y no en rejilla: en un movil la rejilla se queda
       en columnas estrechas y cada URL se parte en varias lineas, lo que
       empujaba el CV a una segunda pagina. Asi ocupa lo mismo con
       cualquier ancho de pantalla. */
    .cv-links {
      display: block;
      margin-top: 5pt;
      font-size: 8.6pt;
      line-height: 1.5;
    }

    .cv-links li {
      display: inline;
    }

    .cv-links li::after {
      content: " · ";
      color: #999;
    }

    .cv-links li:last-child::after {
      content: "";
    }

    /* La propia URL ya dice de que red es */
    .cv-link-label {
      display: none;
    }

    .cv-link {
      color: #111 !important;
      border-bottom: none;
      text-decoration: underline;
    }

    .cv-section {
      margin-top: 12pt;
      /* Evita que un bloque se parta entre dos páginas */
      break-inside: avoid;
    }

    .cv-section-title {
      color: #000 !important;
      font-size: 8.4pt;
      letter-spacing: 0.13em;
      margin-bottom: 5pt;
      border-bottom: 1px solid #ddd;
      padding-bottom: 1.5pt;
    }

    .cv-text,
    .cv-list li,
    .cv-skill-row dd {
      color: #222 !important;
      font-size: 9.6pt;
      line-height: 1.45;
      max-width: none;
    }

    .cv-entry {
      break-inside: avoid;
    }

    .cv-entry + .cv-entry {
      margin-top: 8pt;
    }

    .cv-entry-title {
      color: #000 !important;
      font-size: 10.6pt;
    }

    .cv-entry-sub {
      font-size: 8.8pt;
      margin-top: 0;
    }

    .cv-entry-date {
      font-size: 8.8pt;
    }

    .cv-list {
      margin-top: 2pt;
      gap: 2.5pt;
    }

    .cv-list li {
      padding-left: 0.85rem;
    }

    .cv-list li::before {
      background: #666;
      width: 3.5px;
      height: 3.5px;
      top: 0.55em;
    }

    .cv-skills {
      display: block;
    }

    /* Cada grupo en una linea corrida ("Grupo: items"): igual de legible
       y no depende del ancho, al contrario que la rejilla de dos columnas. */
    .cv-skill-row {
      display: block;
      margin-bottom: 2.5pt;
    }

    .cv-skill-row dt {
      display: inline;
      color: #000 !important;
      font-size: 9.6pt;
    }

    .cv-skill-row dt::after {
      content: ": ";
    }

    .cv-skill-row dd {
      display: inline;
      margin: 0;
    }

    /* Evita que un titulo y su fecha se separen en dos lineas sueltas */
    .cv-entry-head {
      gap: 0.4rem;
    }

    /* Defensa contra una segunda pagina en blanco */
    :global(body) {
      overflow: visible !important;
      height: auto !important;
    }

    .cv-page {
      min-height: 0 !important;
    }

    .cv-section:last-child {
      margin-bottom: 0;
    }
  }
</style>

<script>
  document.getElementById("print-cv")?.addEventListener("click", () => window.print());
</script>
